# ============================================
# VARIÁVEIS DE AMBIENTE - SEO & TRACKING
# ============================================

# URL do site (usado no sitemap e canonical)
PUBLIC_SITE_URL=https://www.alfaaloe.com.br

# ============================================
# GOOGLE TAG MANAGER (GTM)
# ============================================
# Cole aqui o ID do container GTM (ex: GTM-XXXXXXX)
PUBLIC_GTM_ID=

# ============================================
# GOOGLE ANALYTICS 4 (GA4)
# ============================================
# Cole aqui o Measurement ID do GA4 (ex: G-XXXXXXXXXX)
PUBLIC_GA4_ID=

# ============================================
# GOOGLE ADS - CONVERSÕES
# ============================================
# ID da conta Google Ads (ex: AW-XXXXXXXXX)
PUBLIC_GOOGLE_ADS_ID=
# Label de conversão para clique no WhatsApp (ex: xXXXXXXXXXXXXXXXXXX)
PUBLIC_GOOGLE_ADS_WHATSAPP_LABEL=
# Label de conversão para envio de formulário (ex: xXXXXXXXXXXXXXXXXXX)
PUBLIC_GOOGLE_ADS_FORM_LABEL=

# ============================================
# GOOGLE SEARCH CONSOLE
# ============================================
# Meta tag de verificação (cole o conteúdo do atributo content)
PUBLIC_GSC_VERIFICATION=

# ============================================
# META ADS (FACEBOOK PIXEL)
# ============================================
# Cole aqui o ID do Pixel do Facebook (ex: 1234567890123456)
PUBLIC_META_PIXEL_ID=
