---
import '../index.css';
import SEO from '../components/SEO.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Tracking from '../components/Tracking.astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'product';
  publishedAt?: string;
  modifiedAt?: string;
  author?: string;
  keywords?: string[];
  noindex?: boolean;
  schemaType?: 'website' | 'article' | 'faq' | 'product' | 'localBusiness';
  schemaTitle?: string;
  schemaDescription?: string;
  schemaImage?: string;
  schemaBreadcrumbs?: Array<{ name: string; url: string }>;
  schemaArticleBody?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedAt,
  modifiedAt,
  author,
  keywords,
  noindex,
  schemaType = 'website',
  schemaTitle,
  schemaDescription,
  schemaImage,
  schemaBreadcrumbs = [],
  schemaArticleBody,
} = Astro.props;

const canonicalUrl = Astro.url.href;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      url={canonicalUrl}
      type={type}
      publishedAt={publishedAt}
      modifiedAt={modifiedAt}
      author={author}
      keywords={keywords}
      noindex={noindex}
    />
    <SchemaOrg
      type={schemaType}
      title={schemaTitle || title}
      description={schemaDescription || description}
      url={canonicalUrl}
      image={schemaImage || image}
      publishedAt={publishedAt}
      modifiedAt={modifiedAt}
      author={author}
      breadcrumbs={schemaBreadcrumbs}
      articleBody={schemaArticleBody}
    />
    <Tracking />
  </head>
  <body>
    <slot />
  </body>
</html>
