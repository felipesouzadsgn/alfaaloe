---
import Layout from '../layouts/Layout.astro';
import LinksPage from '../sections/LinksPage';

const breadcrumbs = [
  { name: 'Home', url: 'https://www.alfaaloe.com.br/' },
  { name: 'Links', url: 'https://www.alfaaloe.com.br/links/' },
];
---

<Layout 
  title="Especialista Forever Living | Links e Informações"
  description="Acesse todos os meus links: Catálogo Forever Living, Oportunidade FBO, Blog e Contato Direto."
  image="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=1200&auto=format&fit=crop"
  type="website"
  schemaType="website"
  schemaBreadcrumbs={breadcrumbs}
>
  <LinksPage client:load />
</Layout>
